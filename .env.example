# Built to Rank — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Web3Forms contact form access key. Get one at https://web3forms.com/
# This is exposed client-side by Web3Forms' design — fine to use here.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Leave empty during local dev to no-op analytics.
# Create a property at https://analytics.google.com/
NEXT_PUBLIC_GA_ID=
